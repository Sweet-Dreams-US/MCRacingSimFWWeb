# ============================================================================
# MC Racing Sim Fort Wayne — Environment Variables
# ============================================================================
# DO NOT commit real values. Production lives in Vercel project env vars.
# Pull a local copy with: vercel env pull .env.local
# ============================================================================

# ---------- App URL ----------
NEXT_PUBLIC_URL=https://mcracingfortwayne.com

# ---------- Supabase ----------
# Project: mc-racing-sim-fw (gniqzosrrnlrczmeeryd)
NEXT_PUBLIC_SUPABASE_URL=https://gniqzosrrnlrczmeeryd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# Service role key — SERVER ONLY. Bypasses RLS. Get from Supabase dashboard:
# Settings → API → Reveal "service_role" key. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Stripe ----------
# Live keys in Production env. Test keys in Preview/Development envs.
# Use a restricted key (rk_live_*) for the secret — never the full sk_live_*
STRIPE_SECRET_KEY=REPLACE_WITH_RESTRICTED_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_PUBLISHABLE_KEY
# Webhook signing secret — created when we deploy the webhook endpoint.
# Stripe Dashboard → Developers → Webhooks → add endpoint → reveal signing secret
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
# Stripe Terminal location ID (for the in-person reader at the venue)
STRIPE_TERMINAL_LOCATION_ID=REPLACE_WITH_TERMINAL_LOCATION_ID

# ---------- Resend (transactional email) ----------
# User is verifying a domain — once verified, paste the API key here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# From address — must match the verified domain
RESEND_FROM_EMAIL=bookings@mcracingfortwayne.com
# Owner notification address (gets internal booking alerts + calendar event mirrors)
OWNER_NOTIFICATION_EMAIL=mcracingfortwayne@gmail.com

# ---------- Marketing email (promotions / deals / retargeting) ----------
# All of these have correct production defaults in code — set them only to
# override. Marketing sends from a SEPARATE subdomain so a promo complaint can't
# hurt booking-confirmation deliverability.
# Public site URL used to build unsubscribe links (NO trailing slash).
NEXT_PUBLIC_SITE_URL=https://www.mcracingfortwayne.com
# Marketing from-address — must be on a Resend-VERIFIED domain. Default is the
# dedicated subdomain; verify send.mcracingfortwayne.com in Resend first.
# (Temporarily set to an @mcracingfortwayne.com address to test before the
#  subdomain is verified.)
MARKETING_FROM_EMAIL=hello@send.mcracingfortwayne.com
MARKETING_FROM_NAME=MC Racing Sim Fort Wayne
# Where replies go (a real, monitored inbox).
MARKETING_REPLY_TO=mcracingfortwayne@gmail.com
# CAN-SPAM requires a valid physical postal address in every marketing email.
MARKETING_POSTAL_ADDRESS=1205 W Main St, Fort Wayne, IN 46808
# Signing secret for the Resend webhook (delivery/bounce/complaint tracking +
# auto-suppression). Create the webhook in Resend → copy its "Signing Secret".
# Until set, the webhook still works but is unverified (logs a warning).
RESEND_WEBHOOK_SECRET=whsec_REPLACE_WITH_RESEND_WEBHOOK_SECRET

# ---------- Google Calendar (for owner's booking calendar) ----------
# Service account JSON OR OAuth refresh token — TBD when wired up.
# Calendar to write to: mcracingfortwayne@gmail.com
GOOGLE_CALENDAR_ID=mcracingfortwayne@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxxxxxxxxxxxx@xxxxxxxxxx.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----\n

# ---------- Cron job secret (any random string for API security) ----------
CRON_SECRET=your-random-secret-here

# ---------- Legacy: Google Apps Script + Twilio (being phased out) ----------
# Keep these set until full Stripe + Supabase migration is complete.
NEXT_PUBLIC_BOOKING_SCRIPT_URL=https://script.google.com/macros/s/YOUR_BOOKING_SCRIPT_ID/exec
NEXT_PUBLIC_CHECKIN_SCRIPT_URL=https://script.google.com/macros/s/YOUR_CHECKIN_SCRIPT_ID/exec
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
OWNER_PHONE_NUMBER=+18082202600
